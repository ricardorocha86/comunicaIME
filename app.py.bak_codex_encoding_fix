        def wrap_text_cell(value, row_id, col_name):
            raw = "-" if value is None else str(value)
            safe_full = escape(raw).replace("\n", "<br>")
            preview = raw.replace("\n", " ").strip()
            if len(preview) > 90:
                preview = preview[:87] + "..."
            safe_preview = escape(preview) if preview else "-"
            modal_id = f"{table_prefix}-modal-cell-{row_id}-{abs(hash(col_name)) % 10000}"

            modal_fragments.append(
                (
                    f'<div id="{modal_id}" class="cell-modal">'
                    f'  <a href="#" class="cell-modal-backdrop"></a>'
                    f'  <div class="cell-modal-card">'
