def page_dashboard_solicitacoes():
    render_header_banner()
    st.header("ðŸ“Š Dashboard de SolicitaÃ§Ãµes")
    st.markdown("Gerenciamento de todas as demandas de comunicaÃ§Ã£o enviadas pelos docentes.")
    
    solicitacoes = listar_documentos("solicitacoes")
    
    if not solicitacoes:
        st.info("Nenhuma solicitaÃ§Ã£o encontrada no banco de dados.")
        render_persistent_footer()
        return

    # OrdenaÃ§Ã£o: Data de publicaÃ§Ã£o mais prÃ³xima primeiro (ascendente)
    solicitacoes.sort(key=lambda x: x.get("data_publicacao", "9999-12-31"))

    def formatar_br(data_val):
        if not data_val: return "N/A"
        try:
            # Caso jÃ¡ seja um objeto datetime (raro via REST, mas possÃ­vel localmente)
            if isinstance(data_val, datetime):
