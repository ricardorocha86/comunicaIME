                    f'      <a href="#" class="cell-modal-close">Fechar</a>'
                    f"    </div>"
                    f'    <div class="cell-modal-body">{safe_full}</div>'
                    f"  </div>"
                    f"</div>"
                )
            )

            return (
                f'<a class="cell-preview-link" href="#{modal_id}">'
                f'  <div class="cell-limit">{safe_preview}</div>'
                f"</a>"
            )

        for row_id in df.index:
