        ],
        rename_map={
            "status": "Status",
            "periodo_inicio": "Inicio",
            "periodo_fim": "Fim",
            "data_solicitacao": "Recebido em",
            "solicitante": "Solicitante",
            "tipo_evento": "Evento",
            "local_evento": "Local",
            "apoios_necessarios": "Apoios",
            "unidade": "Unidade",
            "solicitando_como": "Perfil",
            "email": "E-mail",
