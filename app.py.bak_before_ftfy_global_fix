            return

        def normalizar_links_anexo(valor):
            if isinstance(valor, list):
                return [u.strip() for u in valor if isinstance(u, str) and u.strip().startswith("http")]
            if isinstance(valor, str) and valor.strip().startswith("http"):
                return [valor.strip()]
            return []

        def preparar_coluna_data(df_local, coluna):
            if coluna not in df_local.columns:
                return
            serie = pd.to_datetime(df_local[coluna], errors="coerce")
            try:
                if getattr(serie.dt, "tz", None) is not None:
                    serie = serie.dt.tz_convert(None)
            except Exception:
                pass
            df_local[coluna] = serie

        dados_formatados = []
        for sol in dados:
            linha = sol.copy()
            linha.pop("tentativas_ia", None)
            linha["anexos"] = normalizar_links_anexo(linha.get("anexos"))

            if isinstance(linha.get("apoios_necessarios"), list):
                linha["apoios_necessarios"] = ", ".join(linha["apoios_necessarios"]) if linha["apoios_necessarios"] else "Não informado"

            if "canais" in linha:
                linha["canais"] = channels_label(linha.get("canais"))
            dados_formatados.append(linha)

        df = pd.DataFrame(dados_formatados)
        if df.empty:
            st.info("Nenhuma solicitação encontrada nesta categoria.")
            return

        cols_existentes = [c for c in colunas_ordem if c in df.columns]
        if not cols_existentes:
            st.info("Não há colunas para exibição nesta categoria.")
            return

        df = df[cols_existentes].copy()

        for c in date_cols:
            preparar_coluna_data(df, c)

        for coluna_ordem in ["data_solicitacao", "data_publicacao", "periodo_inicio", "periodo_fim"]:
            if coluna_ordem in df.columns:
                df = df.sort_values(by=coluna_ordem, ascending=False, na_position="last").reset_index(drop=True)
                break

        colunas_visiveis = []
        colunas_link_anexos = []

        if "anexos" in df.columns:
            df["anexos"] = df["anexos"].apply(normalizar_links_anexo)
            df["_anexos_total"] = df["anexos"].apply(len)
            df["_anexos_markdown"] = df["anexos"].apply(montar_links_markdown)

            max_anexos = int(df["_anexos_total"].max()) if not df.empty else 0
            for idx in range(1, max_anexos + 1):
                nome_col = f"_anexo_link_{idx}"
                colunas_link_anexos.append(nome_col)
                df[nome_col] = df["anexos"].apply(lambda urls, i=idx - 1: urls[i] if i < len(urls) else None)

        for c in cols_existentes:
            if c == "anexos":
                colunas_visiveis.append("_anexos_total")
                colunas_visiveis.extend(colunas_link_anexos)
            else:
                colunas_visiveis.append(c)

        colunas_visiveis = [c for c in colunas_visiveis if c in df.columns]
        if not colunas_visiveis:
            st.info("Não há colunas para exibição nesta categoria.")
            return

        df_view = df[colunas_visiveis].copy()

        rotulos_colunas = {}
        for c in colunas_visiveis:
            if c == "_anexos_total":
                rotulos_colunas[c] = "Qtd. de anexos"
            elif c.startswith("_anexo_link_"):
                rotulos_colunas[c] = f"Anexo {c.split('_')[-1]}"
            else:
                rotulos_colunas[c] = rename_map.get(c, c)

        df_view = df_view.rename(columns=rotulos_colunas)

        coluna_config = {}
        width_por_coluna = {
            "status": "small",
            "responsavel_nex": "small",
            "solicitante": "medium",
            "email": "large",
            "tipo": "medium",
            "tipo_evento": "medium",
            "unidade": "medium",
            "local_evento": "medium",
            "solicitando_como": "small",
            "canais": "medium",
            "apoios_necessarios": "large",
            "descricao": "large",
        }

        for c in colunas_visiveis:
            rotulo = rotulos_colunas[c]
            largura_padrao = width_por_coluna.get(c, "medium")

            if c == "status":
                coluna_config[rotulo] = st.column_config.SelectboxColumn(
                    label=rotulo,
                    width=largura_padrao,
                    options=[
                        STATUS_PENDENTE,
                        STATUS_EM_PRODUCAO_ARTES,
                        STATUS_CONCLUIDO,
                        STATUS_APROVADO_ENVIADO,
                    ],
                )
            elif c in date_cols:
                coluna_config[rotulo] = st.column_config.DatetimeColumn(
                    label=rotulo,
                    width="medium",
                    format="DD/MM/YYYY - HH:mm",
                )
            elif c == "_anexos_total":
                coluna_config[rotulo] = st.column_config.NumberColumn(
                    label=rotulo,
                    width="small",
                    format="%d",
                )
            elif c.startswith("_anexo_link_"):
                indice = c.split("_")[-1]
                coluna_config[rotulo] = st.column_config.LinkColumn(
                    label=rotulo,
                    width="small",
                    display_text=f"Abrir {indice}",
                )
            elif c == "descricao":
                coluna_config[rotulo] = st.column_config.TextColumn(
                    label=rotulo,
                    width=largura_padrao,
                )
            else:
                coluna_config[rotulo] = st.column_config.TextColumn(
                    label=rotulo,
                    width=largura_padrao,
                )

        altura_tabela = min(680, max(260, 110 + (len(df_view) * 42)))
        table_state = st.dataframe(
            df_view,
            key=f"{table_prefix}_dataframe",
            width="stretch",
            height=altura_tabela,
            hide_index=True,
            row_height=44,
            column_config=coluna_config,
            on_select="rerun",
            selection_mode="single-row",
        )

        st.caption("Selecione uma linha para visualizar os detalhes e anexos em Markdown clicável.")

        linhas_selecionadas = []
        if hasattr(table_state, "selection"):
            selection = table_state.selection
            if isinstance(selection, dict):
                linhas_selecionadas = selection.get("rows", []) or []
            elif hasattr(selection, "rows"):
                linhas_selecionadas = selection.rows or []

        if linhas_selecionadas:
            idx = linhas_selecionadas[0]
            linha_detalhe = df.iloc[idx]

            with st.container(border=True):
                st.markdown("**Detalhes da linha selecionada**")
                for c in cols_existentes:
                    if c == "anexos":
                        st.markdown("**Anexos**")
                        st.markdown(linha_detalhe.get("_anexos_markdown", "Sem anexos."))
                        continue

                    valor = linha_detalhe.get(c)
                    if isinstance(valor, pd.Timestamp):
                        valor = valor.strftime("%d/%m/%Y - %H:%M")
                    elif valor is None:
                        valor = "-"
                    elif isinstance(valor, str) and not valor.strip():
                        valor = "-"
                    else:
                        try:
                            if pd.isna(valor):
                                valor = "-"
                        except Exception:
                            pass

                    st.markdown(f"**{rename_map.get(c, c)}:** {valor}")

    render_collection_table(
        collection_name="solicitacoes",
        section_title="Solicitações de Divulgação",
        colunas_ordem=[
            "status",
            "data_publicacao",
            "data_solicitacao",
