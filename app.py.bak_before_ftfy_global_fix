            "anexos": "Anexos",
        },
        date_cols=["data_solicitacao", "data_publicacao"],
        table_prefix="divulgacao",
    )

    st.divider()

    render_collection_table(
        collection_name="solicitacoes_eventos_transmissoes",
        section_title="Solicitações de Apoio a Eventos e Transmissões",
        colunas_ordem=[
            "status",
